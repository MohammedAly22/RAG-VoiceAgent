# ── Voice Agent secrets — copy to .env and fill in. .env is gitignored. ──────

# Google Gemini (default LLM + multimodal ingest vision). Required unless you
# switch llm.backend to "vllm" in config.yaml.
GEMINI_API_KEY=

# LiveKit (self-hosted local server). These dev keys must match the ones the
# local LiveKit server is started with (scripts/start_livekit.sh sets them too).
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret_dev_please_change_0123456789abcdef
LIVEKIT_URL=ws://127.0.0.1:7880

# Optional: HuggingFace token (for gated model downloads, e.g. some LLMs).
HF_TOKEN=
